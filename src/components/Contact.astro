---
import { t } from '../i18n/utils';

interface Props {
  locale: 'vi' | 'en';
}
const { locale } = Astro.props;
---
<section id="contact" class="relative py-24 sm:py-32">
  <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-accent-pink/30 to-transparent"></div>

  <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-4">
      {t(locale, 'contact.title')}
    </h2>
    <p class="text-text-muted text-base sm:text-lg mb-10">
      {t(locale, 'contact.subtitle')}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 items-center justify-center">
      <!-- Facebook -->
      <a
        href="https://www.facebook.com/profile.php?id=61585545301719"
        target="_blank"
        rel="noopener noreferrer"
        data-nyx-mood="waving"
        class="inline-flex items-center gap-3 px-7 py-3.5 rounded-2xl bg-bg-card border border-accent-purple/20 hover:border-accent-violet/50 hover:bg-accent-purple/10 transition-all duration-200 font-semibold text-text-primary text-sm w-full sm:w-auto justify-center group"
      >
        <!-- Facebook icon -->
        <svg class="w-5 h-5 text-blue-400 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
        </svg>
        {t(locale, 'contact.facebook')}
      </a>

      <!-- Zalo -->
      <a
        href="https://zalo.me/0931254059"
        target="_blank"
        rel="noopener noreferrer"
        data-nyx-mood="waving"
        class="inline-flex items-center gap-3 px-7 py-3.5 rounded-2xl bg-bg-card border border-accent-purple/20 hover:border-accent-violet/50 hover:bg-accent-purple/10 transition-all duration-200 font-semibold text-text-primary text-sm w-full sm:w-auto justify-center group"
      >
        <svg class="w-5 h-5 group-hover:scale-110 transition-transform" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="48" height="48" rx="10" fill="#0068FF"/>
          <path d="M24 8C15.163 8 8 14.716 8 23c0 4.681 2.31 8.86 5.938 11.672L12.5 40l5.61-2.47A17.2 17.2 0 0024 38c8.837 0 16-6.716 16-15S32.837 8 24 8z" fill="white"/>
          <path d="M16 27l7-8h-6.5v-2H27v1l-7 8H27v2H16v-1z" fill="#0068FF"/>
          <path d="M29 18h2v9h-2zM29 28.5a1.5 1.5 0 103 0 1.5 1.5 0 00-3 0z" fill="#0068FF"/>
        </svg>
        {t(locale, 'contact.zalo')}
      </a>

      <!-- GitHub -->
      <a
        href="https://github.com/ToyzZone"
        target="_blank"
        rel="noopener noreferrer"
        data-nyx-mood="waving"
        class="inline-flex items-center gap-3 px-7 py-3.5 rounded-2xl bg-bg-card border border-accent-purple/20 hover:border-accent-violet/50 hover:bg-accent-purple/10 transition-all duration-200 font-semibold text-text-primary text-sm w-full sm:w-auto justify-center group"
      >
        <!-- GitHub icon -->
        <svg class="w-5 h-5 text-text-primary group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        {t(locale, 'contact.github')}
      </a>
    </div>
  </div>
</section>
